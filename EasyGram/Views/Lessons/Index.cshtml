@model IEnumerable<EasyGram.ViewModels.LessonProgressViewModel>

@{
    ViewData["Title"] = "Уроки";
    Layout = "_Layout";
}

<h1 class="mb-4" style="font-weight:700;">Уроки</h1>

@foreach (var lesson in Model)
{
    var percent = lesson.ProgressPercent;

    <a href="@Url.Action("Details", "Lessons", new { id = lesson.LessonId })"
       style="text-decoration:none; color:inherit;">
        <div class="card mb-3 shadow-sm" style="border-radius:18px; cursor:pointer; transition: box-shadow .2s;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="card-title mb-2" style="font-weight:600;">@lesson.LessonTitle</h5>

                    <span style="color: #222; font-size:16px;">
                        <b>@lesson.SolvedTasks</b>/<b>@lesson.TotalTasks</b> задач зачтено
                    </span>
                </div>
                <div class="d-flex align-items-center">
                    <div class="progress" style="width: 160px; height:12px; margin-right:20px; border-radius:7px;">
                        <div class="progress-bar bg-success" style="width:@percent%; border-radius:7px;">
                        </div>
                    </div>
                    <span style="font-size: 22px; color: #18b218; min-width:50px; text-align:right;">
                        <b>@percent %</b>
                    </span>
                </div>
            </div>
        </div>
    </a>
}
