@model IEnumerable<EasyGram.Models.Lesson>
@{
    ViewData["Title"] = "Уроки";
    Layout = "_Layout";
}

<h1 class="mb-4 fw-bold">Уроки</h1>

@foreach (var lesson in Model)
{
    var completed = lesson.Tasks.Count(t => t.IsCompleted);
    var total = lesson.Tasks.Count();
    var percent = total > 0 ? (int)Math.Round(completed * 100.0 / total) : 0;

    <div class="lesson-card">
        <div class="lesson-info">
            <h5>@lesson.Title</h5>
            @if (lesson.Deadline != null)
            {
                <div class="deadline text-muted">
                    <i class="fa-regular fa-clock"></i>
                    @($"до {lesson.Deadline:dd MMMM, HH:mm}")
                </div>
            }
            <div class="small text-muted">
                <b>@completed</b>/<b>@total</b> задач зачтено
            </div>
        </div>
        <div class="d-flex align-items-center">
            <div class="lesson-progress me-3">
                <div class="progress">
                    <div class="progress-bar" style="width:@percent%"></div>
                </div>
            </div>
            <span class="fw-bold me-3" style="min-width:50px;">@percent %</span>
            <a class="lesson-link" href="@Url.Action("Details", "Lessons", new { id = lesson.Id })">
                <i class="fa-solid fa-chevron-right"></i>
            </a>
        </div>
    </div>
}
