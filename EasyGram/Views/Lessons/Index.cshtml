@model IEnumerable<EasyGram.Models.Lesson>
@{
    ViewData["Title"] = "Уроки";
    Layout = "_Layout";
}

<h1 class="mb-4" style="font-weight:700;">Уроки2</h1>

@foreach (var lesson in Model)
{
    // Пример расчёта прогресса (подправь, если у тебя хранятся CompletedTasks и TotalTasks):
    var completed = lesson.Tasks.Count(t => t.IsCompleted); // если есть такое поле, иначе задай 0
    var total = lesson.Tasks.Count();
    var percent = total > 0 ? (int)Math.Round(completed * 100.0 / total) : 0;

    <div class="card mb-3 shadow-sm" style="border-radius:18px;">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h5 class="card-title mb-2" style="font-weight:600;">@lesson.Title</h5>
                <div class="text-muted mb-1" style="font-size:15px;">
                    <i class="fa fa-clock-o"></i>
                    @($"до {lesson.Deadline:dd MMMM, HH:mm}") — Дедлайн пройшёл
                </div>
                <span style="color: #222; font-size:16px;">
                    <b>@completed</b>/<b>@total</b> задач зачтено
                </span>
            </div>
            <div class="d-flex align-items-center">
                <div class="progress" style="width: 160px; height:12px; margin-right:20px; border-radius:7px;">
                    <div class="progress-bar bg-success" style="width:@percent%; border-radius:7px;">
                    </div>
                </div>
                <span style="font-size: 22px; color: #18b218; min-width:50px; text-align:right;">
                    <b>@percent %</b>
                </span>
                <a href="@Url.Action("Details", "Lessons", new { id = lesson.Id })"
                   class="btn btn-outline-success rounded-circle ms-3">
                    <i class="fa fa-check"></i>
                </a>
            </div>
        </div>
    </div>
}
