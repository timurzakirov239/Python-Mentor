@{
    ViewBag.Title = "Python Mentor — обучение Python для школьников";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .main-bg {
        background: #f9fafb;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .main-title {
        color: #306998;
        font-size: 2.5rem;
        font-weight: bold;
    }

    .main-subtitle {
        color: #444;
        font-size: 1.25rem;
        margin: 20px auto 30px auto;
        max-width: 600px;
    }

    .main-btn {
        background: #FFD43B;
        color: #306998;
        font-weight: bold;
        font-size: 1.15rem;
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 16px rgba(48,105,152,0.10);
        padding: 15px 42px;
        transition: background 0.2s cubic-bezier(.4,0,.2,1), box-shadow 0.2s cubic-bezier(.4,0,.2,1), transform 0.12s cubic-bezier(.4,0,.2,1);
        outline: none;
    }

        .main-btn:hover, .main-btn:focus {
            background: #f7c71b;
            color: #306998;
            box-shadow: 0 8px 24px rgba(48,105,152,0.15);
            transform: scale(1.045);
            cursor: pointer;
            text-decoration: none;
        }
</style>
<div class="main-bg">
    <div class="container py-5">
        <div class="row align-items-center justify-content-center">
            <div class="col-lg-6 text-center text-lg-left mb-4 mb-lg-0">
                <h1 class="main-title mb-4">
                    Учись программировать на Python легко!
                </h1>
                <p class="main-subtitle">
                    Практические задания, моментальная проверка, индивидуальный прогресс —<br>
                    всё это для школьников, которые хотят стать уверенными пользователями Python.
                </p>
                @if (User.Identity.IsAuthenticated)
                {
                    <a href="/Practice" class="main-btn mt-3">
                        Перейти к заданиям
                    </a>
                }
                else
                {
                    <a href="/Account/Register" class="main-btn mt-3">
                        Начать бесплатно
                    </a>
                }

            </div>
            <div class="col-lg-4 d-flex justify-content-center">
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg"
                     alt="Python"
                     style="max-width: 250px; background: #fff; border-radius: 24px; box-shadow: 0 4px 24px rgba(33,150,243,0.08); padding: 32px;">
            </div>
        </div>
        <div class="row mt-5 justify-content-center">
            <div class="col-md-10">
                <div class="card p-4 border-0 shadow-sm" style="border-radius: 16px;">
                    <h2 class="mb-4 text-center" style="color: #306998;">Почему выбирают Python Mentor?</h2>
                    <div class="row text-center">
                        <div class="col-md-4 mb-3">
                            <div style="font-size: 2.2rem; color:#FFD43B;">⚡</div>
                            <h5 class="mt-2" style="color:#306998;">Практика и моментальная проверка</h5>
                            <p>Выполняй реальные задания и тут же получай обратную связь с разбором ошибок.</p>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div style="font-size: 2.2rem; color:#FFD43B;">👩‍💻</div>
                            <h5 class="mt-2" style="color:#306998;">Удобно и понятно школьнику</h5>
                            <p>Лёгкая теория, удобный интерфейс, прогресс в виде достижений и баллов.</p>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div style="font-size: 2.2rem; color:#FFD43B;">🏆</div>
                            <h5 class="mt-2" style="color:#306998;">Сертификат за прохождение курса</h5>
                            <p>Получай награды и именной сертификат, если успешно прошёл курс!</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
