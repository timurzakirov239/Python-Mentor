@model EasyGram.ViewModels.Exam.ExamViewModel

@{
    ViewBag.Title = "Экзамен: " + Model.ExamTitle;
    var totalMinutes = (int)Model.Duration.TotalMinutes;
}

<style>
    .tasks-list {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .task-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #fff;
        border-radius: 18px;
        padding: 18px 28px;
        box-shadow: 0 2px 14px rgba(44, 89, 164, 0.07);
        font-size: 1.17rem;
        font-weight: 400;
        margin-bottom: 0px;
        transition: box-shadow 0.16s;
    }

        .task-card:hover {
            box-shadow: 0 8px 30px rgba(44, 89, 164, 0.13);
        }

    .task-title {
        flex: 1;
    }

    .task-score {
        margin-left: 20px;
        color: #262b38;
        font-weight: 500;
        font-size: 1.07em;
    }

    .open-btn {
        margin-left: 32px;
        background: #357cff;
        color: #fff;
        border-radius: 10px;
        padding: 8px 26px;
        border: none;
        text-align: center;
        text-decoration: none;
        font-weight: 500;
        font-size: 1.05em;
        transition: background 0.15s;
        box-shadow: none;
        cursor: pointer;
    }

        .open-btn:hover, .open-btn:focus {
            background: #2259b4;
            color: #fff;
            text-decoration: none;
        }

    .back-to-exam-list {
        display: inline-block;
        margin-bottom: 18px;
        background: none;
        border: 1.5px solid #357cff;
        color: #357cff;
        border-radius: 10px;
        padding: 6px 22px;
        font-size: 1.06em;
        font-weight: 500;
        transition: background 0.13s, color 0.13s;
        text-decoration: none;
    }

        .back-to-exam-list:hover, .back-to-exam-list:focus {
            background: #357cff;
            color: #fff;
            text-decoration: none;
        }
</style>

<div class="container mt-4">
    <div class="row">
        <div class="col-12 d-flex justify-content-between align-items-center mb-3">
            <h2 style="font-weight:700;">@Model.ExamTitle</h2>
            <div id="timer" class="badge bg-warning text-dark fs-5" style="min-width:120px;">
                <i class="fa fa-clock"></i>
                <span id="minutes">@totalMinutes</span>:<span id="seconds">00</span>
            </div>
        </div>
        <div class="col-12 mb-4">
            <p style="font-size:1.1em; color:#333;">@Model.ExamDescription</p>
        </div>

        <!-- Кнопка возврата к списку экзаменов -->
        <div class="col-12">
            <a asp-controller="Exam" asp-action="Index" class="back-to-exam-list">
                ← Ко всем экзаменам
            </a>
        </div>

        <div style="margin-top: 35px; margin-bottom: 40px;">
            <h3 style="font-weight: bold; font-size: 2rem; text-align: center; margin-bottom: 28px;">Задания</h3>
            <div class="tasks-list">
                @foreach (var task in Model.Tasks)
                {
                    <div class="task-card">
                        <span class="task-title">
                            @if (task.IsCompleted)
                            {
                                <i class="fa fa-check-circle text-success" style="margin-right:8px;"></i>
                            }
                            @task.Title
                        </span>
                        <span class="task-score">Баллы: @task.MaxScore</span>
                        <a asp-controller="Exam" asp-action="TaskDetails" asp-route-id="@task.Id" class="open-btn">Открыть</a>
                    </div>
                }

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let minutes = @totalMinutes - 1;
        let seconds = 60;

        function updateTimer() {
            if (seconds === 0) {
                if (minutes === 0) {
                    document.getElementById("timer").classList.remove("bg-warning");
                    document.getElementById("timer").classList.add("bg-danger");
                    document.getElementById("timer").innerText = "Время вышло!";
                    clearInterval(interval);
                    // Можно добавить автоматическую отправку экзамена
                    return;
                } else {
                    minutes--;
                    seconds = 59;
                }
            } else {
                seconds--;
            }
            document.getElementById("minutes").innerText = minutes.toString().padStart(2, '0');
            document.getElementById("seconds").innerText = seconds.toString().padStart(2, '0');
        }

        updateTimer();
        let interval = setInterval(updateTimer, 1000);
    </script>
}
