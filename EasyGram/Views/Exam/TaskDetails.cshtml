@model EasyGram.ViewModels.Exam.ExamTaskViewModel

<div class="container mt-5">

    <!-- Кнопка возврата к заданиям экзамена (передаёт id экзамена) 
    <a asp-controller="Exam" asp-action="Start" asp-route-id="@ViewBag.ExamId" class="btn btn-outline-primary mb-4">
        ← К заданиям экзамена
    </a> -->


    <h1 class="mb-3" style="font-weight:700;">@Model.Title</h1>
    <div class="mb-2 text-muted">
        <span>Максимум баллов: <b>@Model.MaxScore</b></span>
    </div>
    <!-- Блок условия -->
    <div class="card shadow-sm mb-4" style="border-radius:16px;">
        <div class="card-body" style="font-size:1.15em;">
            @Html.Raw(Model.Description)
        </div>
    </div>
    <div class="row">
        <!-- Левая часть: редактор кода -->
        <div class="col-lg-7 mb-4">
            <form asp-action="CheckTask" method="post">
                <input type="hidden" name="TaskId" value="@Model.Id" />
                <label for="UserCode" class="form-label"><b>Ваш код:</b></label>
                <textarea name="UserCode" id="UserCode" class="form-control" rows="12" style="font-family:monospace;">@Model.UserCode</textarea>
                <button type="submit" class="btn btn-warning mt-3 px-4 py-2">Отправить решение</button>
            </form>
        </div>
        <!-- Правая часть: вывод результата -->
        <div class="col-lg-5 mb-4">
            <h5 class="mb-3">Вывод</h5>
            <div class="card" style="min-height:120px; border-radius:12px;">
                <div class="card-body" style="font-family:monospace;">
                    @if (ViewBag.Result != null)
                    {
                        <span>@Html.Raw(ViewBag.Result.Replace("\n", "<br/>"))</span>
                    }
                    else
                    {
                        <span class="text-muted">Результат появится здесь после отправки решения</span>
                    }
                </div>
            </div>
        </div>
    </div>
    @* Если хочешь отображать время отправки — добавь это в модель и раскомментируй: *@
    @*
    @if (Model.SubmissionTime != null)
    {
    <div class="mt-3 text-end text-muted">
    Последняя отправка: @Model.SubmissionTime.Value.ToString("dd.MM.yyyy HH:mm")
    </div>
    }
    *@
</div>
