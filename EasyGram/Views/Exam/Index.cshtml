@model IEnumerable<EasyGram.Models.Exam>

@{
    ViewBag.Title = "Экзамены";
}

<div class="container mt-5">
    <h2 class="text-center mb-4">Экзамены</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">Экзамены пока не добавлены.</div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-md-10">
                <table class="table table-bordered table-hover bg-white shadow rounded">
                    <thead class="thead-light">
                        <tr>
                            <th>Название экзамена</th>
                            <th>Описание</th>
                            <th>Время</th>
                            <th style="width: 170px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exam in Model)
                        {
                            <tr>
                                <td>
                                    <b>@exam.Title</b>
                                </td>
                                <td>
                                    @exam.Description
                                </td>
                                <td>
                                    @exam.Duration.ToString(@"hh\:mm")
                                </td>
                                <td>
                                    <a class="btn btn-primary w-100" asp-action="Start" asp-route-id="@exam.Id">
                                        Начать экзамен
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
