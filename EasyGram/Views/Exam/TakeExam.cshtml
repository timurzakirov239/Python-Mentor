@model EasyGram.ViewModels.Exam.ExamViewModel


@{
    ViewData["Title"] = "Экзамен";
    Layout = "_Layout";
}

<div class="container">
    <h1 class="mb-3">@Model.ExamTitle</h1>
    <p>@Model.ExamDescription</p>

    <div class="alert alert-info">
        Время на выполнение: <strong>@Model.Duration.TotalMinutes</strong> минут
    </div>

    <form asp-action="Submit" method="post">
        @foreach (var task in Model.Tasks)
        {
            <div class="card mb-4 shadow-sm p-3">
                <h5 class="mb-2">@task.Title</h5>
                <textarea name="answers[@task.Id]" class="form-control" rows="8" placeholder="Введите ваш код здесь..."></textarea>
            </div>
        }

        <button type="submit" class="btn btn-success mt-3">Сдать экзамен</button>
    </form>
</div>
